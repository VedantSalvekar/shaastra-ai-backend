# Pre-commit hook to detect secrets
# Copy this to .git/hooks/pre-commit and make it executable:
# chmod +x .git/hooks/pre-commit

#!/bin/bash

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Checking for secrets before commit..."

# Check if any .env files are being committed
if git diff --cached --name-only | grep -E '\.env$|\.env\..*'; then
    echo -e "${RED}❌ ERROR: .env file detected in commit!${NC}"
    echo "   You are trying to commit environment files."
    echo "   These should NEVER be committed to git."
    echo ""
    echo "   To fix this:"
    echo "   1. Remove the file from staging: git reset HEAD .env"
    echo "   2. Ensure .env is in .gitignore"
    echo ""
    exit 1
fi

# Check for common API key patterns in staged files
FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(py|js|ts|jsx|tsx|yml|yaml|json)$')

if [ -n "$FILES" ]; then
    # Check for OpenAI keys (sk-proj-, sk-...)
    if echo "$FILES" | xargs git diff --cached | grep -iE 'sk-proj-[a-zA-Z0-9]{20,}|sk-[a-zA-Z0-9]{20,}'; then
        echo -e "${RED}❌ ERROR: Possible OpenAI API key detected!${NC}"
        echo "   Pattern: sk-proj-... or sk-..."
        echo ""
        echo "   To fix this:"
        echo "   1. Remove the key from your code"
        echo "   2. Use environment variables instead"
        echo "   3. Rotate the exposed key at https://platform.openai.com/api-keys"
        echo ""
        exit 1
    fi

    # Check for common secret patterns
    if echo "$FILES" | xargs git diff --cached | grep -iE 'api[_-]?key.*["\047]:[[:space:]]*["\047][a-zA-Z0-9]{20,}|secret.*["\047]:[[:space:]]*["\047][a-zA-Z0-9]{20,}'; then
        echo -e "${YELLOW}⚠️  WARNING: Possible API key or secret detected!${NC}"
        echo "   Please review your changes carefully."
        echo ""
        read -p "   Are you sure you want to continue? (yes/no): " response
        if [[ ! "$response" =~ ^[Yy][Ee][Ss]$ ]]; then
            echo "   Commit aborted."
            exit 1
        fi
    fi

    # Check for hardcoded passwords
    if echo "$FILES" | xargs git diff --cached | grep -iE 'password.*=.*["\047][^"\047]{8,}["\047]'; then
        echo -e "${YELLOW}⚠️  WARNING: Possible hardcoded password detected!${NC}"
        echo "   Please review your changes carefully."
        echo ""
        read -p "   Are you sure you want to continue? (yes/no): " response
        if [[ ! "$response" =~ ^[Yy][Ee][Ss]$ ]]; then
            echo "   Commit aborted."
            exit 1
        fi
    fi
fi

echo "✅ No secrets detected. Proceeding with commit..."
exit 0

